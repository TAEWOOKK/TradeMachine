# ── Tier 1: 필수 (값을 반드시 채워야 동작) ──
KIS_APP_KEY=your_app_key_here
KIS_APP_SECRET=your_app_secret_here
KIS_CANO=your_account_number_here
KIS_ACNT_PRDT_CD=01
KIS_BASE_URL=https://openapivts.koreainvestment.com:29443
WATCH_LIST=005930,000660,035720

# ── Tier 2: 선택 (기본값 있음, 필요 시 오버라이드) ──
# KIS_IS_PAPER_TRADING=true
# TRADING_INTERVAL_MINUTES=5
# SIGNAL_LOOKBACK_DAYS=7
# SIGNAL_CONFIRM_DAYS=3
# SELL_CONFIRM_DAYS=2
# VOLUME_CONFIRM_RATIO=1.5
# RSI_OVERBOUGHT=70
# RSI_OVERSOLD=30
# MAX_INVESTMENT_RATIO=1.0  # (레거시) 종목당 투자=가용금/목표종목수. MAX_HOLDING_COUNT 또는 관심종목 수 기준
# MAX_HOLDING_COUNT=0  # 0=제한없음, 5 등 양수=최대 보유 종목 수
# MAX_DAILY_BUY_COUNT=3
# MAX_HOLDING_DAYS=2
# STOP_LOSS_RATE=-2.0
# TAKE_PROFIT_RATE=2.0
# TRAILING_STOP_ACTIVATE=1.5
# TRAILING_STOP_RATE=0.8
# REBUY_COOLDOWN_HOURS=24
# SCALPING_ENTRY_MINUTE=25
# MIN_INTRADAY_CHANGE=0.3
# MAX_INTRADAY_CHANGE=4.0
# RSI_SCALPING_MIN=50
# RSI_SCALPING_MAX=65
# ENABLE_MARKET_FILTER=true
# EOD_CLOSE_ENABLED=true
